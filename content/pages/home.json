    },
    {
      "type": "custom_html",
      "html": "<nav class=\"fixed w-full z-50 bg-tuscany-cream/95 backdrop-blur-md border-b border-tuscany-sand transition-all duration-300 py-4\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center\">\n            <div class=\"flex-shrink-0 flex items-center gap-2 cursor-pointer group\">\n                <!-- Simple SVG Logo -->\n                <svg class=\"w-8 h-8 text-tuscany-terracotta group-hover:rotate-12 transition-transform duration-500\" fill=\"currentColor\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M18.3 5.4c-1.3-1.3-3.2-1.8-5-1.4l-.5-1.5c-.2-.6-.9-1-1.6-1H8.5c-.7 0-1.4.4-1.6 1L6.4 4C4.6 3.6 2.7 4.1 1.4 5.4c-1.9 1.9-2.2 4.9-.7 7 1.2 1.7 3.3 2.5 5.3 2.1l1.5 4.5c.3.8 1.1 1.4 2 1.4h5c.9 0 1.7-.6 2-1.4l1.5-4.5c2 .4 4.1-.4 5.3-2.1 1.5-2.1 1.2-5.1-.7-7zm-14.7 5.6c-1-.9-1-2.4 0-3.3.9-1 2.3-1.1 3.3-.3l-1.9 5.6c-1.2-.4-2.1-1.1-2.8-2zm12.3 7.5h-5l-2.2-6.5c1.4.5 2.9.8 4.4.8h.6c1.5 0 3-.3 4.4-.8l-2.2 6.5zm5.1-7.5c-.7.9-1.6 1.6-2.8 2l-1.9-5.6c1-.8 2.4-.7 3.3.3.9.9 1 2.4 0 3.3zM8 22h8v2H8z\"></path>\n                </svg>\n                <span class=\"font-serif text-2xl font-bold tracking-tight text-tuscany-charcoal\">La Bottega</span>\n            </div>\n            \n            <div class=\"hidden md:flex space-x-8 items-center\">\n                <a href=\"#about\" class=\"text-sm font-semibold tracking-wide text-tuscany-brown hover:text-tuscany-terracotta transition-colors\">Our Story</a>\n                <a href=\"#menu\" class=\"text-sm font-semibold tracking-wide text-tuscany-brown hover:text-tuscany-terracotta transition-colors\">Menu</a>\n                <a href=\"#visit\" class=\"text-sm font-semibold tracking-wide text-tuscany-brown hover:text-tuscany-terracotta transition-colors\">Visit Us</a>\n            </div>\n\n            <div>\n                <a href=\"#visit\" class=\"inline-flex items-center justify-center px-6 py-2.5 border border-transparent text-sm font-bold tracking-wide rounded-sm text-white bg-tuscany-terracotta hover:bg-tuscany-terracottaDark hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300\">\n                    Order Ahead\n                </a>\n            </div>\n        </div>\n    </nav>"
    },
    {
      "type": "custom_html",
      "html": "<section class=\"relative h-screen w-full flex items-center justify-center overflow-hidden\">\n        <!-- Background Image -->\n        <div class=\"absolute inset-0 z-0\">\n            <img src=\"https://picsum.photos/seed/rusticitalycafe/1920/1080\" alt=\"Rustic Cafe Interior\" class=\"w-full h-full object-cover\" referrerpolicy=\"no-referrer\">\n        </div>\n        <!-- Dark Gradient Overlay for Contrast -->\n        <div class=\"absolute inset-0 z-10 bg-gradient-to-b from-black/60 via-black/40 to-black/70\"></div>\n\n        <!-- Content -->\n        <div class=\"relative z-20 text-center px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto mt-16\">\n            <span class=\"block text-tuscany-gold font-sans font-bold tracking-[0.2em] uppercase text-sm mb-4\">Benvenuti</span>\n            <h1 class=\"font-serif text-5xl md:text-7xl lg:text-8xl text-white font-bold leading-tight mb-6 drop-shadow-lg\">\n                A Taste of Tuscany, <br>\n                <span class=\"italic text-tuscany-sand font-light\">Poured Locally.</span>\n            </h1>\n            <p class=\"mt-4 text-lg md:text-2xl text-tuscany-sand font-light mb-10 max-w-2xl mx-auto drop-shadow-md\">\n                Experience the slow-roasted warmth and unhurried charm of Italian coffee culture, right in the heart of your neighborhood.\n            </p>\n            <div class=\"flex flex-col sm:flex-row gap-4 justify-center\">\n                <a href=\"#menu\" class=\"inline-flex items-center justify-center px-8 py-4 border border-transparent text-base font-bold tracking-wide rounded-sm text-white bg-tuscany-terracotta hover:bg-tuscany-terracottaDark hover:shadow-xl hover:-translate-y-1 transition-all duration-300\">\n                    Explore the Menu\n                </a>\n                <a href=\"#about\" class=\"inline-flex items-center justify-center px-8 py-4 border border-white/50 text-base font-bold tracking-wide rounded-sm text-white bg-white/10 backdrop-blur-sm hover:bg-white/20 hover:border-white transition-all duration-300\">\n                    Discover Our Story\n                </a>\n            </div>\n        </div>\n    </section>"
    },
    {
      "type": "custom_html",
      "html": "<section id=\"about\" class=\"py-32 bg-tuscany-cream bg-texture relative overflow-hidden\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 items-center\">\n                \n                <!-- Image Block (col-span-5) with overlapping secondary image -->\n                <div class=\"lg:col-span-5 relative group\">\n                    <div class=\"relative rounded-t-full rounded-b-md overflow-hidden shadow-2xl shadow-tuscany-charcoal/10 border-4 border-white aspect-[3/4]\">\n                        <img src=\"https://picsum.photos/seed/baristapour/800/1000\" alt=\"Barista pouring espresso\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\" referrerpolicy=\"no-referrer\">\n                        <div class=\"absolute inset-0 bg-tuscany-charcoal/10 mix-blend-multiply\"></div>\n                    </div>\n                    <!-- Decorative overlapping element -->\n                    <div class=\"absolute -bottom-12 -right-12 w-48 h-48 rounded-full border-8 border-tuscany-cream overflow-hidden shadow-xl shadow-black/10 hidden md:block\">\n                        <img src=\"https://picsum.photos/seed/coffebeans/400/400\" alt=\"Freshly roasted coffee beans\" class=\"w-full h-full object-cover\" referrerpolicy=\"no-referrer\">\n                    </div>\n                </div>\n\n                <!-- Text Block (col-span-7) -->\n                <div class=\"lg:col-span-7 lg:pl-10\">\n                    <span class=\"text-tuscany-terracotta font-bold tracking-widest uppercase text-sm mb-2 block\">La Nostra Storia</span>\n                    <h2 class=\"font-serif text-4xl md:text-5xl text-tuscany-charcoal mb-8 leading-tight\">\n                        Good Coffee, <br>\n                        <span class=\"italic text-tuscany-olive\">Takes Time.</span>\n                    </h2>\n                    \n                    <div class=\"space-y-6 text-tuscany-brown text-lg leading-relaxed\">\n                        <p>\n                            Inspired by the sun-drenched terraced hills of Val d'Orcia, La Bottega was founded on a singular philosophy: coffee is not merely a transaction, it is a ritual. We source exclusively from small-batch producers who honor the earth.\n                        </p>\n                        <p>\n                            Every shot pulled on our custom lever machines is an homage to the traditional Italian craft. No syrups. No rushing. Just pure, unadulterated espresso served in an environment designed to make you linger.\n                        </p>\n                    </div>\n\n                    <div class=\"mt-10\">\n                        <a href=\"#\" class=\"group inline-flex items-center text-tuscany-charcoal font-bold text-lg hover:text-tuscany-terracotta transition-colors\">\n                            <span class=\"border-b-2 border-tuscany-terracotta pb-1\">Meet our Roasters</span>\n                            <svg class=\"ml-2 w-5 h-5 group-hover:translate-x-2 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\"></path></svg>\n                        </a>\n                    </div>\n                </div>\n\n            </div>\n        </div>\n    </section>"
    },
    {
      "type": "custom_html",
      "html": "<section id=\"menu\" class=\"py-32 bg-tuscany-sand relative border-y border-[#E8DFD1]\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n            \n            <div class=\"text-center max-w-3xl mx-auto mb-20\">\n                <h2 class=\"font-serif text-4xl md:text-5xl text-tuscany-charcoal mb-4\">Signature Offerings</h2>\n                <p class=\"text-tuscany-brown text-lg\">Curated selections balancing rustic tradition with refined technique.</p>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10\">\n                \n                <!-- Product Card 1 -->\n                <div class=\"group bg-tuscany-cream rounded-xl overflow-hidden shadow-xl shadow-black/5 hover:-translate-y-2 hover:shadow-2xl transition-all duration-300 flex flex-col\">\n                    <div class=\"relative h-64 overflow-hidden\">\n                        <img src=\"https://picsum.photos/seed/latteart/600/400\" alt=\"Tuscan Flat White\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-500\" referrerpolicy=\"no-referrer\">\n                        <div class=\"absolute top-4 right-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-sm text-sm font-bold text-tuscany-charcoal\">$5.50</div>\n                    </div>\n                    <div class=\"p-8 flex-grow flex flex-col justify-between\">\n                        <div>\n                            <h3 class=\"font-serif text-2xl text-tuscany-charcoal mb-2\">Il Classico Flat White</h3>\n                            <p class=\"text-tuscany-brown text-sm leading-relaxed mb-6\">A double ristretto shot of our Siena blend, seamlessly integrated with micro-textured whole milk. Rich, velvety, and balanced.</p>\n                        </div>\n                        <button class=\"w-full py-3 border border-tuscany-olive text-tuscany-olive font-bold uppercase tracking-wider text-sm rounded-sm hover:bg-tuscany-olive hover:text-white transition-colors duration-300\">\n                            Add to Order\n                        </button>\n                    </div>\n                </div>\n\n                <!-- Product Card 2 -->\n                <div class=\"group bg-tuscany-cream rounded-xl overflow-hidden shadow-xl shadow-black/5 hover:-translate-y-2 hover:shadow-2xl transition-all duration-300 flex flex-col\">\n                    <div class=\"relative h-64 overflow-hidden\">\n                        <img src=\"https://picsum.photos/seed/affogato/600/400\" alt=\"Artisan Affogato\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-500\" referrerpolicy=\"no-referrer\">\n                        <div class=\"absolute top-4 right-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-sm text-sm font-bold text-tuscany-charcoal\">$7.00</div>\n                    </div>\n                    <div class=\"p-8 flex-grow flex flex-col justify-between\">\n                        <div>\n                            <h3 class=\"font-serif text-2xl text-tuscany-charcoal mb-2\">Artisan Affogato</h3>\n                            <p class=\"text-tuscany-brown text-sm leading-relaxed mb-6\">House-made Fior di Latte gelato \"drowned\" in a piping hot shot of our darkest roast. The perfect afternoon indulgence.</p>\n                        </div>\n                        <button class=\"w-full py-3 border border-tuscany-olive text-tuscany-olive font-bold uppercase tracking-wider text-sm rounded-sm hover:bg-tuscany-olive hover:text-white transition-colors duration-300\">\n                            Add to Order\n                        </button>\n                    </div>\n                </div>\n\n                <!-- Product Card 3 -->\n                <div class=\"group bg-tuscany-cream rounded-xl overflow-hidden shadow-xl shadow-black/5 hover:-translate-y-2 hover:shadow-2xl transition-all duration-300 flex flex-col\">\n                    <div class=\"relative h-64 overflow-hidden\">\n                        <img src=\"https://picsum.photos/seed/rosemarycake/600/400\" alt=\"Rosemary Olive Oil Cake\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-500\" referrerpolicy=\"no-referrer\">\n                        <div class=\"absolute top-4 right-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-sm text-sm font-bold text-tuscany-charcoal\">$6.50</div>\n                    </div>\n                    <div class=\"p-8 flex-grow flex flex-col justify-between\">\n                        <div>\n                            <h3 class=\"font-serif text-2xl text-tuscany-charcoal mb-2\">Rosemary Olive Oil Cake</h3>\n                            <p class=\"text-tuscany-brown text-sm leading-relaxed mb-6\">Baked fresh daily. Moist, subtly sweet, and infused with cold-pressed Tuscan olive oil and fresh rosemary sprigs.</p>\n                        </div>\n                        <button class=\"w-full py-3 border border-tuscany-olive text-tuscany-olive font-bold uppercase tracking-wider text-sm rounded-sm hover:bg-tuscany-olive hover:text-white transition-colors duration-300\">\n                            Add to Order\n                        </button>\n                    </div>\n                </div>\n\n            </div>\n\n            <div class=\"mt-16 text-center\">\n                <a href=\"#\" class=\"inline-flex items-center text-tuscany-terracotta font-bold hover:text-tuscany-terracottaDark transition-colors group\">\n                    <span class=\"mr-2\">View Full Menu</span>\n                    <svg class=\"w-5 h-5 group-hover:translate-x-1 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14 5l7 7m0 0l-7 7m7-7H3\"></path></svg>\n                </a>\n            </div>\n\n        </div>\n    </section>"
    },
    {
      "type": "custom_html",
      "html": "<section class=\"py-32 bg-tuscany-cream\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <div class=\"grid grid-cols-1 md:grid-cols-12 gap-4 h-auto md:h-[600px]\">\n                \n                <!-- Large Left Image (col-span-7) -->\n                <div class=\"md:col-span-7 relative group overflow-hidden rounded-l-2xl rounded-r-sm h-96 md:h-full\">\n                    <img src=\"https://picsum.photos/seed/cafeinteriorwarm/1000/800\" alt=\"Warm cafe interior\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000\" referrerpolicy=\"no-referrer\">\n                    <div class=\"absolute inset-0 bg-gradient-to-t from-tuscany-charcoal/80 via-transparent to-transparent opacity-80\"></div>\n                    <div class=\"absolute bottom-8 left-8 right-8\">\n                        <h3 class=\"font-serif text-3xl text-white mb-2\">Designed to Linger</h3>\n                        <p class=\"text-tuscany-sand text-sm max-w-md\">Terracotta tiles, exposed brick, and the hum of quiet conversation. Bring a book.</p>\n                    </div>\n                </div>\n\n                <!-- Right Side Stacked Images (col-span-5) -->\n                <div class=\"md:col-span-5 grid grid-rows-2 gap-4 h-96 md:h-full\">\n                    <div class=\"relative overflow-hidden rounded-tr-2xl rounded-bl-sm rounded-tl-sm rounded-br-sm group\">\n                         <img src=\"https://picsum.photos/seed/espressomachine/600/400\" alt=\"Vintage espresso machine\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" referrerpolicy=\"no-referrer\">\n                    </div>\n                    <div class=\"relative overflow-hidden rounded-br-2xl rounded-tl-sm rounded-tr-sm rounded-bl-sm group bg-tuscany-olive flex items-center justify-center p-8 text-center\">\n                        <div>\n                            <svg class=\"w-10 h-10 text-tuscany-gold mx-auto mb-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg>\n                            <h4 class=\"font-serif text-xl text-white mb-2\">Take a Pause</h4>\n                            <p class=\"text-tuscany-sand/80 text-sm\">Escape the rush of the city. We don't offer Wi-Fi, we offer connection.</p>\n                        </div>\n                    </div>\n                </div>\n\n            </div>\n        </div>\n    </section>"
    },
    {
      "type": "custom_html",
      "html": "<section id=\"visit\" class=\"bg-tuscany-olive relative\">\n        <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row\">\n            \n            <!-- Text Content (approx 40%) -->\n            <div class=\"w-full md:w-5/12 py-24 px-8 md:px-12 lg:px-20 text-tuscany-sand flex flex-col justify-center\">\n                <h2 class=\"font-serif text-4xl text-white mb-8\">Visit La Bottega</h2>\n                \n                <div class=\"mb-10\">\n                    <h4 class=\"font-bold tracking-wider uppercase text-sm text-tuscany-gold mb-2\">Location</h4>\n                    <p class=\"text-lg leading-relaxed\">\n                        142 Vintage Street<br>\n                        Artisan District, AD 90210\n                    </p>\n                </div>\n\n                <div class=\"mb-12\">\n                    <h4 class=\"font-bold tracking-wider uppercase text-sm text-tuscany-gold mb-4\">Opening Hours</h4>\n                    <ul class=\"space-y-3\">\n                        <li class=\"flex justify-between border-b border-white/20 pb-2\">\n                            <span>Mon - Fri</span>\n                            <span class=\"font-serif italic text-white\">7:00 am - 4:00 pm</span>\n                        </li>\n                        <li class=\"flex justify-between border-b border-white/20 pb-2\">\n                            <span>Saturday</span>\n                            <span class=\"font-serif italic text-white\">8:00 am - 5:00 pm</span>\n                        </li>\n                        <li class=\"flex justify-between pb-2\">\n                            <span>Sunday</span>\n                            <span class=\"font-serif italic text-white\">Closed (Rest Day)</span>\n                        </li>\n                    </ul>\n                </div>\n\n                <a href=\"#\" class=\"inline-block bg-white text-tuscany-olive font-bold text-center py-4 px-8 rounded-sm hover:bg-tuscany-gold hover:text-tuscany-charcoal transition-all shadow-lg hover:-translate-y-1\">\n                    Get Directions\n                </a>\n            </div>\n\n            <!-- Image/Map (approx 60%) -->\n            <div class=\"w-full md:w-7/12 h-[500px] md:h-auto relative\">\n                <img src=\"https://picsum.photos/seed/cafeexteriorplants/1200/1000\" alt=\"Cafe Exterior\" class=\"absolute inset-0 w-full h-full object-cover\" referrerpolicy=\"no-referrer\">\n                <!-- Overlay badge mimicking a map pin -->\n                <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white/95 backdrop-blur-md p-4 rounded-full shadow-2xl flex items-center justify-center group cursor-pointer hover:scale-110 transition-transform\">\n                    <svg class=\"w-8 h-8 text-tuscany-terracotta\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z\" clip-rule=\"evenodd\"></path></svg>\n                </div>\n            </div>\n\n        </div>\n    </section>"
    },
    {
      "type": "custom_html",
      "html": "<footer class=\"bg-tuscany-charcoal text-tuscany-sand pt-20 pb-10\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <div class=\"grid grid-cols-1 md:grid-cols-12 gap-12 mb-16 border-b border-white/10 pb-16\">\n                \n                <!-- Brand -->\n                <div class=\"md:col-span-4\">\n                    <span class=\"font-serif text-3xl text-white block mb-4\">La Bottega</span>\n                    <p class=\"text-tuscany-sand/70 text-sm leading-relaxed mb-6 max-w-xs\">\n                        Bringing the unhurried, quality-focused coffee culture of Tuscany to our local community. One cup at a time.\n                    </p>\n                    <div class=\"flex space-x-4\">\n                        <!-- Social Icons -->\n                        <a href=\"#\" class=\"text-tuscany-sand/50 hover:text-tuscany-gold transition-colors\">\n                            <svg class=\"w-6 h-6\" fill=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z\"></path></svg>\n                        </a>\n                        <a href=\"#\" class=\"text-tuscany-sand/50 hover:text-tuscany-gold transition-colors\">\n                            <svg class=\"w-6 h-6\" fill=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z\"></path></svg>\n                        </a>\n                    </div>\n                </div>\n\n                <!-- Links -->\n                <div class=\"md:col-span-2\">\n                    <h5 class=\"font-bold uppercase tracking-wider text-sm text-white mb-6\">Explore</h5>\n                    <ul class=\"space-y-3\">\n                        <li><a href=\"#\" class=\"text-tuscany-sand/70 hover:text-white transition-colors text-sm\">Our Story</a></li>\n                        <li><a href=\"#\" class=\"text-tuscany-sand/70 hover:text-white transition-colors text-sm\">Full Menu</a></li>\n                        <li><a href=\"#\" class=\"text-tuscany-sand/70 hover:text-white transition-colors text-sm\">Coffee Beans</a></li>\n                        <li><a href=\"#\" class=\"text-tuscany-sand/70 hover:text-white transition-colors text-sm\">Wholesale</a></li>\n                    </ul>\n                </div>\n\n                <!-- Newsletter -->\n                <div class=\"md:col-span-6 lg:col-span-5 lg:col-start-8\">\n                    <h5 class=\"font-bold uppercase tracking-wider text-sm text-white mb-6\">Join The Club</h5>\n                    <p class=\"text-tuscany-sand/70 text-sm mb-4\">Subscribe for updates on seasonal beans, exclusive tastings, and community events.</p>\n                    <form class=\"flex flex-col sm:flex-row gap-3\">\n                        <input type=\"email\" placeholder=\"Email address\" class=\"w-full bg-white/5 border border-white/10 rounded-sm px-4 py-3 text-white placeholder:text-tuscany-sand/40 focus:outline-none focus:border-tuscany-terracotta focus:ring-1 focus:ring-tuscany-terracotta transition-all\">\n                        <button type=\"submit\" class=\"bg-tuscany-terracotta text-white font-bold px-6 py-3 rounded-sm hover:bg-tuscany-terracottaDark transition-colors whitespace-nowrap\">\n                            Subscribe\n                        </button>\n                    </form>\n                </div>\n\n            </div>\n\n            <div class=\"flex flex-col md:flex-row justify-between items-center text-xs text-tuscany-sand/50\">\n                <p>© 2023 La Bottega del Caffè. All rights reserved.</p>\n                <div class=\"flex space-x-6 mt-4 md:mt-0\">\n                    <a href=\"#\" class=\"hover:text-white transition-colors\">Privacy Policy</a>\n                    <a href=\"#\" class=\"hover:text-white transition-colors\">Terms of Service</a>\n                </div>\n            </div>\n        </div>\n    </footer>"
